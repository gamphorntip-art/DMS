  <script>
    // --- ตั้งค่า Google Apps Script URL ---
    // นำ URL ที่ได้จากการ Deploy ของ Google Apps Script มาใส่ตรงนี้
    const GAS_URL = 'https://script.google.com/macros/s/AKfycbzJFjpSs0kFW_RXp2TRa5rXPF6anQcjXhq-T0kci7LEkyYQVMQIBZyNRGqhy2hPUbQfHA/exec';
    
    // --- State Management ---
    let documents = [];

    // Initialize the app by loading data from Google Sheets
    async function initApp() {
      document.getElementById('darDate').value = new Date().toISOString().split('T')[0];
      
      showToast('กำลังโหลดข้อมูลจากฐานข้อมูล...', 'warning');
      
      try {
        if (GAS_URL === 'ใส่_URL_ของ_GOOGLE_APPS_SCRIPT_ที่นี่') {
          showToast('⚠️ คุณยังไม่ได้ตั้งค่า GAS_URL ข้อมูลชั่วคราวจะถูกโหลดแทน', 'error');
          const savedData = localStorage.getItem('dms_documents');
          if (savedData) documents = JSON.parse(savedData);
        } else {
          // ดึงข้อมูลจาก Google Sheets (GET request)
          const response = await fetch(GAS_URL);
          const data = await response.json();
          documents = data;
          showToast('โหลดข้อมูลสำเร็จ!', 'success');
        }
      } catch (error) {
        console.error('Error fetching data:', error);
        showToast('❌ ไม่สามารถดึงข้อมูลได้', 'error');
      }

      setupFormHandlers();
      renderAll();
    }

    // ฟังก์ชันส่งข้อมูลไปยัง Google Sheets
    async function saveToCloud(newData) {
      // อัปเดต Local Array ไว้ก่อนเพื่อให้หน้าจอเปลี่ยนทันทีไม่ต้องรอโหลด
      documents.push(newData);
      renderAll();

      if (GAS_URL === 'ใส่_URL_ของ_GOOGLE_APPS_SCRIPT_ที่นี่') {
        // Fallback ไปใช้ Local Storage ถ้ายังไม่ใส่ URL
        localStorage.setItem('dms_documents', JSON.stringify(documents));
        showToast('✅ บันทึกลงเครื่อง (ยังไม่ได้ต่อ Sheet)', 'success');
        return;
      }

      showToast('กำลังบันทึกลงระบบ...', 'warning');
      try {
        // ส่งข้อมูลไปบันทึกที่ Google Sheets (POST request)
        const response = await fetch(GAS_URL, {
          method: 'POST',
          body: JSON.stringify(newData)
        });
        
        const result = await response.json();
        if (result.success) {
          showToast('✅ บันทึกข้อมูลสำเร็จ!', 'success');
        } else {
          showToast('❌ เกิดข้อผิดพลาดในการบันทึก', 'error');
        }
      } catch (error) {
        console.error('Error saving data:', error);
        showToast('❌ ไม่สามารถติดต่อเซิร์ฟเวอร์ได้', 'error');
      }
    }

    // Clear all memory (ปิดการลบข้อมูลทั้งหมดผ่านหน้าเว็บเพื่อความปลอดภัยของฐานข้อมูล)
    function clearAllData() {
      alert("ไม่สามารถลบข้อมูลทั้งหมดผ่านหน้าเว็บได้ หากต้องการลบข้อมูลกรุณาลบใน Google Sheets โดยตรงครับ");
    }

    // Type mapping
    const typeLabels = {
      QP: 'QP (Quality Procedure)',
      SP: 'SP (Safety Procedure)',
      EP: 'EP (Environment Procedure)',
      WI: 'WI (Work Instruction)',
      FM: 'FM (Form)',
      SD: 'SD (Support Document)',
      QM: 'QM (Manual)',
      Policy: 'Policy'
    };

    // Auto generate DAR Number
    function generateDarNo() {
      const now = new Date();
      const year = now.getFullYear() + 543;
      
      const currentYearRecords = documents.filter(d => {
        const darYear = d.dar_no?.split('/')[1];
        return darYear === year.toString();
      });
      
      const maxSequence = currentYearRecords.length > 0 
        ? Math.max(...currentYearRecords.map(d => parseInt(d.dar_sequence) || 0))
        : 0;
      
      const sequence = maxSequence + 1;
      const sequenceStr = String(sequence).padStart(2, '0');
      return { 
        dar_no: `DAR${sequenceStr}/${year}`,
        sequence: sequence
      };
    }

    // Handlers
    function setupFormHandlers() {
      // 1. CREATE DOC FORM
      document.getElementById('darForm').addEventListener('submit', (e) => {
        e.preventDefault();
        
        const docType = document.getElementById('docType').value;
        const docName = document.getElementById('darDocName').value.trim();
        const docCode = document.getElementById('darDocCode').value.trim();
        const department = document.getElementById('darDepartment').value.trim();
        const editVersion = document.getElementById('darEditVersion').value.trim() || '00';
        const darDate = document.getElementById('darDate').value;
        
        const darInfo = generateDarNo();
        const now = new Date().toISOString();

        const newDar = {
          id: Date.now().toString(),
          dar_no: darInfo.dar_no,
          dar_sequence: darInfo.sequence,
          dar_type: 'create',
          doc_code: docCode,
          doc_name: docName,
          doc_type: docType,
          department: department,
          version: editVersion,
          dar_date: darDate,
          requester_name: document.getElementById('requesterName').value,
          action_details: document.getElementById('darActionDetails').value,
          status: 'active',
          created_at: now,
          updated_at: now
        };

        // ส่งข้อมูลไป Google Sheets
        saveToCloud(newDar);
        
        document.getElementById('darForm').reset();
        document.getElementById('darDate').value = new Date().toISOString().split('T')[0];
      });

      // 2. EDIT DOC FORM
      document.getElementById('editRequestForm').addEventListener('submit', (e) => {
        e.preventDefault();
        const selectedId = document.getElementById('editSelectDoc').value;
        const actionDetails = document.getElementById('editActionDetails').value.trim();
        
        const selectedDoc = documents.find(d => d.id === selectedId);
        if (!selectedDoc) return;

        // Calculate new version
        const allActionsForDoc = documents.filter(d => d.doc_code === selectedDoc.doc_code);
        const maxVersion = Math.max(...allActionsForDoc.map(d => parseInt(d.version) || 0), 0);
        const newVersion = String(maxVersion + 1).padStart(2, '0');

        const darInfo = generateDarNo();
        const now = new Date().toISOString();

        const editRecord = {
          id: Date.now().toString(),
          dar_no: darInfo.dar_no,
          dar_sequence: darInfo.sequence,
          dar_type: 'edit',
          doc_code: selectedDoc.doc_code,
          doc_name: selectedDoc.doc_name,
          doc_type: selectedDoc.doc_type,
          department: selectedDoc.department,
          version: newVersion,
          dar_date: document.getElementById('editDate').value,
          requester_name: document.getElementById('editRequesterName').value,
          action_details: actionDetails,
          status: 'active', // สถานะหลังการแก้ไขก็ยังคง active อยู่
          created_at: now,
          updated_at: now
        };

        // ส่งข้อมูลไป Google Sheets
        saveToCloud(editRecord);
        
        document.getElementById('editRequestForm').reset();
        resetEditForm();
      });

      // 3. CANCEL DOC FORM
      document.getElementById('cancelRequestForm').addEventListener('submit', (e) => {
        e.preventDefault();
        const selectedId = document.getElementById('cancelSelectDoc').value;
        const cancelReason = document.getElementById('cancelReason').value.trim();

        const selectedDoc = documents.find(d => d.id === selectedId);
        if (!selectedDoc) return;

        const darInfo = generateDarNo();
        const now = new Date().toISOString();

        const cancelRecord = {
          id: Date.now().toString(),
          dar_no: darInfo.dar_no,
          dar_sequence: darInfo.sequence,
          dar_type: 'cancel',
          doc_code: selectedDoc.doc_code,
          doc_name: selectedDoc.doc_name,
          doc_type: selectedDoc.doc_type,
          department: selectedDoc.department,
          version: selectedDoc.version,
          dar_date: document.getElementById('cancelDate').value,
          requester_name: document.getElementById('cancelRequesterName').value,
          cancel_reason: cancelReason,
          action_details: cancelReason,
          status: 'cancelled', // แจ้งว่าถูกยกเลิก
          created_at: now,
          updated_at: now
        };

        // Update original document status in local array (the GAS backend will also handle this via script)
        documents.forEach(doc => {
            if(doc.doc_code === selectedDoc.doc_code && doc.dar_type === 'create') {
                doc.status = 'cancelled';
                doc.updated_at = now;
            }
        });

        // ส่งข้อมูลไป Google Sheets
        saveToCloud(cancelRecord);
        
        document.getElementById('cancelRequestForm').reset();
        resetCancelForm();
      });
    }

    // Switch Tabs
    function switchTab(tab) {
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('tab-active');
        btn.classList.add('text-gray-600', 'hover:bg-indigo-100');
      });
      document.getElementById(`tab-${tab}`).classList.add('tab-active');
      document.getElementById(`tab-${tab}`).classList.remove('text-gray-600', 'hover:bg-indigo-100');

      document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.add('hidden'));
      const panel = document.getElementById(`panel-${tab}`);
      panel.classList.remove('hidden');
      panel.classList.add('animate-fade');
      
      if (tab === 'dashboard') renderDashboard();
      if (tab === 'masterlist') renderMasterlist();
      if (tab === 'dar-log') renderDarLog();
    }

    // Get Master Data logic
    function getMasterDocumentInfo(docCode) {
      const createRecord = documents.find(d => d.doc_code === docCode && d.dar_type === 'create');
      if (!createRecord) return null;

      const allActions = documents.filter(d => d.doc_code === docCode);
      const latestVersion = allActions.reduce((latest, doc) => {
        return (parseFloat(doc.version) || 0) > (parseFloat(latest.version) || 0) ? doc : latest;
      }, createRecord);

      const latestAction = allActions.sort((a, b) => new Date(b.created_at) - new Date(a.created_at))[0];

      let status = 'active';
      if (latestAction.dar_type === 'cancel') status = 'cancelled';

      return {
        ...createRecord,
        version: latestVersion.version,
        status: status,
        updated_at: latestAction.created_at
      };
    }

    // Render All
    function renderAll() {
      renderDocCount();
      renderDashboard();
      renderMasterlist();
      renderDarLog();
    }

    function renderDocCount() {
      const activeCreateDocs = documents.filter(d => d.dar_type === 'create' && d.status === 'active');
      document.getElementById('docCount').textContent = `${activeCreateDocs.length} เอกสาร`;
    }

    function renderDashboard() {
      const createDocs = documents.filter(d => d.dar_type === 'create');
      const totalDocs = createDocs.length;
      const activeDocs = createDocs.filter(d => d.status === 'active').length;
      const cancelledDocs = createDocs.filter(d => d.status === 'cancelled').length;
      const totalRecords = documents.length;

      document.getElementById('dashTotalDocs').textContent = totalDocs;
      document.getElementById('dashActiveDocs').textContent = activeDocs;
      document.getElementById('dashCancelledDocs').textContent = cancelledDocs;
      document.getElementById('dashTotalRecords').textContent = totalRecords;

      document.getElementById('dashCreateCount').textContent = totalDocs;
      document.getElementById('dashEditCount').textContent = documents.filter(d => d.dar_type === 'edit').length;
      document.getElementById('dashCancelCount').textContent = documents.filter(d => d.dar_type === 'cancel').length;

      // Type distribution
      const typeCount = {};
      createDocs.forEach(doc => { typeCount[doc.doc_type] = (typeCount[doc.doc_type] || 0) + 1; });
      const typeDistDiv = document.getElementById('dashTypeDistribution');
      if (Object.keys(typeCount).length === 0) {
        typeDistDiv.innerHTML = '<p class="text-gray-400 text-center py-4">ยังไม่มีเอกสาร</p>';
      } else {
        typeDistDiv.innerHTML = Object.entries(typeCount).map(([type, count]) => {
          const percent = Math.round((count / totalDocs) * 100);
          return `
            <div>
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm font-medium text-gray-700">${typeLabels[type] || type}</span>
                <span class="text-sm font-bold text-indigo-600">${count}</span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-2">
                <div class="bg-gradient-to-r from-indigo-400 to-purple-500 h-2 rounded-full" style="width: ${percent}%"></div>
              </div>
            </div>`;
        }).join('');
      }

      // Recent Actions
      const recentDiv = document.getElementById('dashRecentActions');
      const emptyDiv = document.getElementById('dashEmptyActions');
      const sortedDocs = [...documents].sort((a, b) => new Date(b.created_at) - new Date(a.created_at)).slice(0, 5);

      if (sortedDocs.length === 0) {
        recentDiv.innerHTML = '';
        emptyDiv.classList.remove('hidden');
      } else {
        emptyDiv.classList.add('hidden');
        recentDiv.innerHTML = sortedDocs.map(doc => {
          const actionEmoji = doc.dar_type === 'create' ? '🆕' : doc.dar_type === 'edit' ? '✏️' : '❌';
          return `
            <div class="p-3 bg-gray-50 rounded-lg border-l-4 border-indigo-400 hover:bg-indigo-50 transition-colors">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class="text-lg">${actionEmoji}</span>
                  <div class="text-sm">
                    <p class="font-medium text-gray-800">${escapeHtml(doc.doc_name)}</p>
                    <p class="text-xs text-gray-500">${escapeHtml(doc.doc_code)}</p>
                  </div>
                </div>
                <span class="text-xs text-gray-400">${formatDate(doc.created_at)}</span>
              </div>
            </div>`;
        }).join('');
      }
    }

    function renderMasterlist() {
      const search = document.getElementById('searchMaster').value.toLowerCase();
      const statusFilter = document.getElementById('filterStatus').value;
      const uniqueDocCodes = [...new Set(documents.filter(d => d.dar_type === 'create').map(d => d.doc_code))];
      let masterDocs = uniqueDocCodes.map(code => getMasterDocumentInfo(code)).filter(d => d);

      // Filtering
      masterDocs = masterDocs.filter(doc => {
        const matchSearch = doc.doc_code.toLowerCase().includes(search) || doc.doc_name.toLowerCase().includes(search);
        const matchStatus = !statusFilter || doc.status === statusFilter;
        return matchSearch && matchStatus;
      });

      const tbody = document.getElementById('masterlistBody');
      const empty = document.getElementById('emptyMasterlist');

      if (masterDocs.length === 0) {
        tbody.innerHTML = '';
        empty.classList.remove('hidden');
      } else {
        empty.classList.add('hidden');
        tbody.innerHTML = masterDocs.map(doc => `
          <tr class="hover:bg-indigo-50/50 transition-colors">
            <td class="px-4 py-3 font-mono font-semibold text-indigo-600">${escapeHtml(doc.doc_code)}</td>
            <td class="px-4 py-3 font-medium text-gray-800">${escapeHtml(doc.doc_name)}</td>
            <td class="px-4 py-3 text-gray-600">${typeLabels[doc.doc_type] || doc.doc_type}</td>
            <td class="px-4 py-3"><span class="px-3 py-1 bg-indigo-100 text-indigo-700 rounded-full text-sm font-semibold">Rev.${escapeHtml(doc.version)}</span></td>
            <td class="px-4 py-3">${getStatusBadge(doc.status)}</td>
            <td class="px-4 py-3 text-gray-500 text-sm">${formatDate(doc.updated_at)}</td>
          </tr>`).join('');
      }

      // Populate Select Dropdowns for Edit and Cancel Tabs
      const activeCreateDocs = masterDocs.filter(d => d.status === 'active');
      const optionsHtml = '<option value="">-- เลือกเอกสาร --</option>' + activeCreateDocs.map(d => `<option value="${d.id}">${escapeHtml(d.doc_code)} - ${escapeHtml(d.doc_name)}</option>`).join('');
      
      document.getElementById('editSelectDoc').innerHTML = optionsHtml;
      document.getElementById('cancelSelectDoc').innerHTML = optionsHtml;
    }

    function renderDarLog() {
      const sortedDocs = [...documents].sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
      const tbody = document.getElementById('darBody');
      const empty = document.getElementById('emptyDar');

      if (sortedDocs.length === 0) {
        tbody.innerHTML = '';
        empty.classList.remove('hidden');
      } else {
        empty.classList.add('hidden');
        tbody.innerHTML = sortedDocs.map(doc => {
          const actionText = doc.dar_type === 'create' ? '🆕 ขอจัดทำใหม่' : doc.dar_type === 'edit' ? '✏️ ขอแก้ไข' : '❌ ขอยกเลิก';
          return `
          <tr class="hover:bg-rose-50/50 transition-colors">
            <td class="px-4 py-3 text-gray-600">${formatDate(doc.created_at)}</td>
            <td class="px-4 py-3 font-mono font-semibold text-rose-600">${escapeHtml(doc.dar_no)}</td>
            <td class="px-4 py-3 font-mono font-semibold text-rose-600">${escapeHtml(doc.doc_code)}</td>
            <td class="px-4 py-3 font-medium text-gray-800">${escapeHtml(doc.doc_name)}</td>
            <td class="px-4 py-3"><span class="px-3 py-1 bg-rose-100 text-rose-700 rounded-full text-sm font-semibold">Rev.${escapeHtml(doc.version)}</span></td>
            <td class="px-4 py-3 font-semibold">${actionText}</td>
          </tr>`
        }).join('');
      }
    }

    // Load data into Edit Form
    function loadEditDocData() {
      const docId = document.getElementById('editSelectDoc').value;
      if (!docId) return resetEditForm();
      const doc = documents.find(d => d.id === docId);
      
      document.getElementById('editDocCode').textContent = doc.doc_code;
      document.getElementById('editDocName').textContent = doc.doc_name;
      document.getElementById('editDocType').textContent = typeLabels[doc.doc_type] || doc.doc_type;
      
      const master = getMasterDocumentInfo(doc.doc_code);
      document.getElementById('editCurrentVersion').textContent = `v${master.version}`;
      document.getElementById('editDate').value = new Date().toISOString().split('T')[0];

      ['editDocInfo', 'editDetailsSection', 'editRequesterSection'].forEach(id => document.getElementById(id).classList.remove('hidden'));
    }

    function resetEditForm() {
      ['editDocInfo', 'editDetailsSection', 'editRequesterSection'].forEach(id => document.getElementById(id).classList.add('hidden'));
      document.getElementById('editActionDetails').value = '';
    }

    // Load data into Cancel Form
    function loadCancelDocData() {
      const docId = document.getElementById('cancelSelectDoc').value;
      if (!docId) return resetCancelForm();
      const doc = documents.find(d => d.id === docId);
      
      document.getElementById('cancelDocCode').textContent = doc.doc_code;
      document.getElementById('cancelDocName2').textContent = doc.doc_name;
      document.getElementById('cancelDocType').textContent = typeLabels[doc.doc_type] || doc.doc_type;
      
      const master = getMasterDocumentInfo(doc.doc_code);
      document.getElementById('cancelCurrentVersion').textContent = `v${master.version}`;
      document.getElementById('cancelDate').value = new Date().toISOString().split('T')[0];

      ['cancelDocInfo', 'cancelDetailsSection', 'cancelRequesterSection'].forEach(id => document.getElementById(id).classList.remove('hidden'));
    }

    function resetCancelForm() {
      ['cancelDocInfo', 'cancelDetailsSection', 'cancelRequesterSection'].forEach(id => document.getElementById(id).classList.add('hidden'));
      document.getElementById('cancelReason').value = '';
    }

    // Helpers
    function getStatusBadge(status) {
      if (status === 'active') return '<span class="px-3 py-1 status-active text-white rounded-full text-sm font-semibold">✓ ใช้งาน</span>';
      if (status === 'cancelled') return '<span class="px-3 py-1 status-cancelled text-white rounded-full text-sm font-semibold">✗ ยกเลิก</span>';
      return '<span class="px-3 py-1 status-draft text-white rounded-full text-sm font-semibold">📝 ร่าง</span>';
    }

    function formatDate(dateStr) {
      if (!dateStr) return '-';
      return new Date(dateStr).toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
    }

    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function showToast(msg, type = 'success') {
      const toast = document.getElementById('toast');
      document.getElementById('toastMsg').textContent = msg;
      toast.className = toast.className.replace(/bg-\w+-500/g, type === 'error' ? 'bg-red-500' : 'bg-green-500');
      toast.style.transform = 'translateY(0)';
      toast.style.opacity = '1';
      setTimeout(() => { toast.style.transform = 'translateY(20px)'; toast.style.opacity = '0'; }, 3000);
    }

    // Start App
    initApp();
  </script>
